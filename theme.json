{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "82rem",
      "wideSize": "90rem"
    },
    "color": {
      "custom": true,
      "customGradient": true,
      "palette": [
        { "slug": "primary", "name": "Primary", "color": "#132d6b" },
        { "slug": "primary-2", "name": "Primary 2", "color": "#0f2558" },
        { "slug": "text", "name": "Text", "color": "#0f1a2d" },
        { "slug": "muted", "name": "Muted", "color": "#596782" },
        { "slug": "surface", "name": "Surface", "color": "#ffffff" },
        { "slug": "soft", "name": "Soft", "color": "#f5f7fb" },
        { "slug": "soft-2", "name": "Soft 2", "color": "#e9eefb" },
        { "slug": "border", "name": "Border", "color": "#d8dfec" },
        { "slug": "success", "name": "Success", "color": "#3ca174" },
        { "slug": "danger", "name": "Danger", "color": "#d41745" },
        { "slug": "brand-yellow", "name": "Brand Yellow", "color": "#fad47a" }
      ],
      "gradients": [
        {
          "slug": "brand-blue",
          "name": "Brand Blue",
          "gradient": "linear-gradient(140deg, #102a63 0%, #173e88 100%)"
        }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "%", "vw", "vh"],
      "spacingSizes": [
        { "slug": "2xs", "name": "2XS", "size": "0.25rem" },
        { "slug": "xs", "name": "XS", "size": "0.5rem" },
        { "slug": "sm", "name": "SM", "size": "0.75rem" },
        { "slug": "md", "name": "MD", "size": "1rem" },
        { "slug": "lg", "name": "LG", "size": "1.5rem" },
        { "slug": "xl", "name": "XL", "size": "2rem" },
        { "slug": "2xl", "name": "2XL", "size": "3rem" }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "open-sans",
          "name": "Open Sans",
          "fontFamily": "'Open Sans', system-ui, -apple-system, 'Segoe UI', sans-serif"
        }
      ],
      "fontSizes": [
        { "slug": "xs", "name": "XS", "size": "0.75rem" },
        { "slug": "sm", "name": "SM", "size": "0.875rem" },
        { "slug": "md", "name": "MD", "size": "1rem" },
        { "slug": "lg", "name": "LG", "size": "1.125rem" },
        { "slug": "xl", "name": "XL", "size": "1.5rem" },
        { "slug": "2xl", "name": "2XL", "size": "2rem" },
        { "slug": "3xl", "name": "3XL", "size": "2.75rem" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--surface)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--open-sans)",
      "lineHeight": "1.55"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "heading": {
        "typography": {
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "button": {
        "border": {
          "radius": "0.625rem"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        },
        "typography": {
          "fontWeight": "600"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "right": "1rem",
            "bottom": "0.75rem",
            "left": "1rem"
          }
        }
      }
    }
  }
}
